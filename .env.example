# Copy to apps/preview-engine/.env.local for local dev. Never commit a real .env.

# --- Maps adapter (BRI-180) ---
# Server-only key with Places API (New) enabled. Restrict by IP / referrer in GCP.
GOOGLE_PLACES_API_KEY=

# Postgres connection string for the spend log + future v0.0 tables.
# Neon free tier (see ADR-0001 amendment 2026-05-15). Use the *pooled* connection
# string from the Neon dashboard — it's what works from Vercel serverless.
# Server-only. Never expose to the browser bundle (no NEXT_PUBLIC_ prefix).
DATABASE_URL=

# Smoke-test gate. Unit tests run with this unset.
# Set to 1 only when explicitly running scripts/smoke-places.ts against the live API.
PLACES_LIVE=
